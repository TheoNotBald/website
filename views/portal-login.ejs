<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= portal.charAt(0).toUpperCase() + portal.slice(1) %> Login</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="page auth-page">
      <section class="panel narrow auth-glass">
        <p class="eyebrow">Starfall Event Portal</p>
        <h1><%= portal.charAt(0).toUpperCase() + portal.slice(1) %> Access</h1>
        <p class="panel-subtitle">Sign in with your Discord account to continue.</p>

        <% if (error) { %>
        <section class="notice error" style="margin: 0.8rem 0 0.95rem;">
          <%= error %>
        </section>
        <% } %>

        <div class="auth-actions">
          <a href="/auth/discord?portal=<%= portal %>" class="button">Continue with Discord</a>
          <a href="/" class="button button-ghost">Back</a>
        </div>
      </section>
    </main>
  </body>
</html>
