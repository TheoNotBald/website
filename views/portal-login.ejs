<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= portal.charAt(0).toUpperCase() + portal.slice(1) %> Login</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body class="welcome-page-body">
    <main class="welcome-page">
      <section class="welcome-hero">
        <p class="welcome-eyebrow">Starfall Event Portal</p>
        <h1><%= portal.charAt(0).toUpperCase() + portal.slice(1) %> Access</h1>
        <p class="welcome-tagline">Sign in with your Discord account to continue.</p>

        <% if (error) { %>
        <section class="notice error" style="margin: 2rem 0;">
          <%= error %>
        </section>
        <% } %>

        <div class="welcome-cta">
          <a href="/auth/discord?portal=<%= portal %>" class="welcome-primary">Continue with Discord</a>
          <a href="/" class="welcome-secondary">Back</a>
        </div>
      </section>
    </main>
  </body>
</html>
