<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= portal.charAt(0).toUpperCase() + portal.slice(1) %> Login</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="page page-login">
      <section class="hero">
        <p class="eyebrow"><%= portal.charAt(0).toUpperCase() + portal.slice(1) %> Portal</p>
        <h1><%= portal.charAt(0).toUpperCase() + portal.slice(1) %> Login</h1>
        <p class="subtitle">Sign in with your Discord account.</p>
      </section>

      <section class="panel compact-panel">
        <% if (error) { %>
        <section class="notice error"><%= error %></section>
        <% } %>

        <a class="button" href="/auth/discord?portal=<%= portal %>">Continue with Discord</a>

        <a class="link-back" href="/">Back to role selection</a>
      </section>
    </main>
  </body>
</html>
